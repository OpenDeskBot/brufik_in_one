# 本地环境变量（复制为 .env 后填写）
# 勿提交含真实密钥的 .env

# ---------- 必填 ----------
# DashScope OpenAI 兼容 API Key（也可用 DASHSCOPE_API_KEY / QWEN_API_KEY）
LLM_API_KEY=

# 本地 ASR 模型目录（相对 service/ 项目根）
ASR_MODEL_DIR=./models/SenseVoiceSmall

# ---------- 常用可选 ----------
# 主配置文件（默认 config.yaml）
# DESKBOT_SERVER_CONFIG=config.yaml

# WebSocket 服务
# DESKBOT_SERVER_HOST=0.0.0.0
# DESKBOT_SERVER_PORT=9000
# DESKBOT_WS_PATH=/asr_chat
# DESKBOT_WS_PING_INTERVAL=120
# DESKBOT_WS_PING_TIMEOUT=300
# WS_SEND_TIMEOUT_SEC=10

# TTS 后端：doubao（火山引擎豆包，默认）
# TTS_PROVIDER=doubao
# 豆包凭证见 DOUBAO_TTS_* / .env；调试页「TTS 调试」可配置
# TTS_SPK_ID=0
# TTS_SAMPLE_RATE=24000

# pb 脸动画（默认：deskbot-face.json 的 emotions + phonemes）
# DESKBOT_PB_FACE_BUNDLE=demo
# DESKBOT_PB_FACE_BUNDLE_JSON=/path/to/custom_face_bundle.json
# DESKBOT_PB_FACE_BUNDLE_FILE=/path/to/overlay.yaml

# 下行协议开关（默认 pb-only=true，见 config.yaml server.*）
# DESKBOT_ASR_CHAT_DEVICE_PB_ONLY=1
# DESKBOT_ASR_CHAT_MINIMAL_DOWNLINK=0
# DESKBOT_SEND_FACE_INFO=0
# DESKBOT_PB_RANDOM_SERVO=0
# DESKBOT_PB_IDLE_SNORE_SEC=5
# DESKBOT_PB_IDLE_SNORE_SCENE=sleep_snore

# Flask Web 服务（默认监听所有网卡，局域网可访问）
DESKBOT_WEB_HOST=0.0.0.0
# DESKBOT_WEB_PORT=5050
# DESKBOT_WEB_PUBLIC_HOST=
# 启用 Flask 开发服务器 debug 模式（默认关闭；生产环境切勿开启）
# DESKBOT_WEB_DEBUG=0

# ---------- 用户认证（SQLite，邮箱+密码本地登录）----------
# Session 签名密钥（生产环境请设置随机长字符串；亦用于调试台 WS debug_token 签名）
# DESKBOT_WEB_SECRET_KEY=
# 已登录调试台 WebSocket 令牌有效天数（默认 7，最大 30）
# DESKBOT_DEBUG_WS_TOKEN_DAYS=7
# DESKBOT_DB_PATH=./data/opendesk.db
# 首次启动自动创建免费体验 API Key（每日 1GB），写入 data/.free_api_key

# 摄像头（默认读 config.yaml camera_face.*）
# CAMERA_FACE_LANDMARKER_PATH=
# CAMERA_UNDISTORT=0
# CAMERA_CALIB_JSON=
# CAMERA_MIN_FACE_DETECTION_CONFIDENCE=
# CAMERA_MIN_FACE_PRESENCE_CONFIDENCE=

# 日志
# DESKBOT_SERVER_LOG_FILE=app.log
# DESKBOT_SERVER_LOG_LEVEL=INFO

# ---------- 豆包语音 TTS 2.0（可选，调试台 /debug/tts）----------
# 新版控制台：仅需 Seed Speech API Key
# DOUBAO_TTS_API_KEY=
# DOUBAO_TTS_SPEAKER=zh_female_vv_uranus_bigtts
# DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
# DOUBAO_TTS_MODEL=seed-tts-2.0-expressive
# DOUBAO_TTS_WS_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection
# DOUBAO_TTS_SAMPLE_RATE=24000
# DOUBAO_TTS_FORMAT=pcm
# DOUBAO_TTS_ENABLE_TIMESTAMP=1

# ---------- 启动脚本 ----------
# 跳过 pip 重装（venv 须已完整）
FAST_START=0
