# 环境变量（含真实密钥，勿提交）
.env

# 免费体验 API Key（勿提交）
data/.free_api_key

# 本地账号密码备忘（勿提交）
data/.builtin_password

# SQLite 运行时数据库（首次启动自动创建）
data/opendesk.db
data/opendesk.db-shm
data/opendesk.db-wal

# 按设备隔离的运行时数据（配置、session、记忆等，本地生成）
data/device/

# 全局运行时用户数据（含记忆、人脸档案等，本地生成）
data/user_memory.json
data/face_profiles.json
data/face_live_snapshot.json

# Python 虚拟环境
.venv
.venv*/
venv
venv*/
ENV/

# Python 缓存
__pycache__/
.ruff_cache/
*.py[cod]
*.so
*.egg-info/

# 运行时日志 / 音频产物
app.log
*.log
tts_reply.wav
output.wav

# ASR 模型：通过 download_model.py 本地下载，不入仓库
models/

# IDE / OS
.idea/
.vscode/
.DS_Store
