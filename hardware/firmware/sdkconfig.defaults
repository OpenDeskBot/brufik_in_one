CONFIG_ESP_CONSOLE_NONE=y
CONFIG_ARDUINO_LOOP_STACK_SIZE=24576

# 相机 JPEG ~8KB 须一次或少量 TCP 段发完，避免 sendBIN 等 ACK 时 write 超时
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=16384

# Opus 编码任务栈较大，允许任务栈使用 PSRAM（否则 xTaskCreateStatic 会 assert）
CONFIG_SPIRAM=y
CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=y

# ESP-SR: VADNet only (no WakeNet / MultiNet / NSNET)
CONFIG_MODEL_IN_FLASH=y
CONFIG_SR_VADN_VADNET1_MEDIUM=y
CONFIG_SR_NSN_WEBRTC=y
